    style Error503 fill:#fee2e2,stroke:#f87171
    style AirFallback fill:#fef3c7,stroke:#fbbf24
    style ForecastFallback fill:#fef3c7,stroke:#fbbf24
    style UVFallback fill:#fef3c7,stroke:#fbbf24
    style DiseaseFallback fill:#fef3c7,stroke:#fbbf24
    style DiseaseMock fill:#fef3c7,stroke:#fbbf24
    style AirStale fill:#fef3c7,stroke:#fbbf24
    style Return200 fill:#dcfce7,stroke:#22c55e
    style ReturnCached fill:#dcfce7,stroke:#22c55e
